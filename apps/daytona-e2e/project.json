{
  "name": "daytona-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/daytona-e2e",
  "tags": [],
  "implicitDependencies": ["api", "runner", "proxy", "dashboard", "session-daemon"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags e2e -timeout 300s -v -count=1 ./..."
      },
      "cache": true,
      "inputs": [
        "default",
        "^goProduction",
        { "dependentTasksOutputFiles": "**/*", "transitive": true },
        { "env": "DAYTONA_API_URL" },
        { "env": "DAYTONA_API_KEY" }
      ]
    },
    "e2e:cleanup": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags e2e -run TestCleanupStaleSandboxes -v -timeout 60s ./..."
      }
    },
    "e2e:sessions": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags e2e -run TestSession -v -count=1 -timeout 600s ./..."
      },
      "cache": false
    },
    "e2e:scaleout": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags 'e2e scaleout' -run TestSessionScaleOut -v -count=1 -timeout 1200s ./..."
      },
      "cache": false
    },
    "e2e:workloads": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -tags 'e2e workloads' -run TestSessionWorkload -v -count=1 -timeout 1200s ./..."
      },
      "cache": false
    }
  }
}
