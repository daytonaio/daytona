{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "astro dev --host"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "astro build",
          "node ./tools/update-search-local.js",
          "node ./tools/update-llms.js"
        ],
        "parallel": false
      },
      "dependsOn": ["api:openapi"],
      "configurations": {
        "production": {
          "commands": [
            "astro build --prod",
            "node ./tools/update-search-prod.js",
            "node ./tools/update-llms.js"
          ]
        }
      }
    },
    "update-cli-reference": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}/tools",
        "command": "node ./update-cli-reference.js"
      }
    },
    "update-api-reference": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}/tools",
        "command": "node ./update-api-reference.js"
      },
      "dependsOn": ["api:openapi"]
    },
    "check-version-env": {},
    "docker": {
      "options": {
        "target": "docs",
        "build-args": [
          "VERSION=$VERSION",
          "PUBLIC_ALGOLIA_APP_ID=$PUBLIC_ALGOLIA_APP_ID",
          "PUBLIC_ALGOLIA_API_KEY=$PUBLIC_ALGOLIA_API_KEY",
          "PUBLIC_WEB_URL=$PUBLIC_WEB_URL",
          "PUBLIC_ALGOLIA_DOCS_INDEX_NAME=$PUBLIC_ALGOLIA_DOCS_INDEX_NAME",
          "PUBLIC_ALGOLIA_CLI_INDEX_NAME=$PUBLIC_ALGOLIA_CLI_INDEX_NAME",
          "PUBLIC_ALGOLIA_SDK_INDEX_NAME=$PUBLIC_ALGOLIA_SDK_INDEX_NAME"
        ]
      }
    },
    "push-manifest": {}
  },
  "implicitDependencies": ["api"]
}
