---
import Suggested404 from '@components/Suggested404.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>404 · Daytona Docs</title>
  </head>
  <body>
    <main class="wrap">
      <section class="card" aria-labelledby="title">
        <h1 id="title" class="code">404</h1>
        <p class="msg">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="suggested">
          <Suggested404 fallbackLocale="en" />
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  .wrap {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
  }

  .card {
    width: min(720px, 100%);
    text-align: left;
  }

  .code {
    font-size: clamp(4rem, 10vw, 6rem);
    line-height: 1;
    margin: 0 0 0.35rem;
    text-align: center;
  }

  .msg {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
    text-align: center;
  }

  .suggested {
    display: grid;
    gap: 0.25rem;
    justify-items: start;
    width: 100%;
  }

  .suggested :global(.suggested-404-list a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
