{
  "name": "session-daemon",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/session-daemon",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "{projectRoot}/cmd/main.go",
        "outputPath": "dist/apps/session-daemon",
        "env": {
          "CGO_ENABLED": "0"
        }
      },
      "configurations": {
        "production": {
          "flags": ["-ldflags \"-s -w -X 'github.com/daytonaio/session-daemon/internal.Version=$VERSION'\""]
        }
      },
      "inputs": ["goProduction", "^goProduction", { "env": "VERSION" }]
    },
    "build-amd64": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "{projectRoot}/cmd/main.go",
        "outputPath": "dist/apps/session-daemon-amd64",
        "env": {
          "CGO_ENABLED": "0",
          "GOOS": "linux",
          "GOARCH": "amd64"
        }
      },
      "configurations": {
        "production": {
          "flags": ["-ldflags \"-s -w -X 'github.com/daytonaio/session-daemon/internal.Version=$VERSION'\""]
        }
      },
      "inputs": ["goProduction", "^goProduction", { "env": "VERSION" }]
    },
    "render-snapshot-dockerfile": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "parallel": false,
        "commands": [
          "mkdir -p dist/apps/session-daemon-snapshot",
          "test -n \"${SESSION_DAEMON_URL:-}\" || { echo 'ERROR: SESSION_DAEMON_URL must be set (URL to a pre-built session-daemon-amd64 binary reachable by the build runner)' >&2; exit 1; }",
          "envsubst '${SESSION_DAEMON_URL} ${SESSION_DAEMON_SHA256}' < {projectRoot}/snapshot.Dockerfile > dist/apps/session-daemon-snapshot/snapshot.rendered.Dockerfile",
          "echo 'Rendered snapshot Dockerfile -> dist/apps/session-daemon-snapshot/snapshot.rendered.Dockerfile'"
        ]
      }
    },
    "create-snapshot": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "cwd": "{workspaceRoot}",
        "parallel": false,
        "commands": [
          "command -v daytona >/dev/null || { echo 'ERROR: daytona CLI not on PATH. Build it via `nx build cli` or install a published release.' >&2; exit 1; }",
          "daytona snapshot create ${SNAPSHOT_NAME:-python-default} --dockerfile dist/apps/session-daemon-snapshot/snapshot.rendered.Dockerfile --cpu ${SNAPSHOT_CPU:-2} --memory ${SNAPSHOT_MEMORY:-2} --disk ${SNAPSHOT_DISK:-5}"
        ]
      },
      "dependsOn": ["render-snapshot-dockerfile"]
    },
    "serve": {
      "executor": "@nx-go/nx-go:serve",
      "options": {
        "cmd": "gow",
        "main": "{projectRoot}/cmd/main.go"
      }
    },
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    },
    "check-version-env": {}
  }
}
