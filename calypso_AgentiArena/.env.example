# =============================================
# AgentArena AI Sub-Agent Deployment Config
# Copy this file to .env and fill in the values
# =============================================

# API keys for the sub-agents (change in production!)
ATLAS_API_KEY=your-production-atlas-api-key-here
SNIPER_API_KEY=your-production-sniper-api-key-here

# Rate limiting (requests per minute per IP)
RATE_LIMIT=30
