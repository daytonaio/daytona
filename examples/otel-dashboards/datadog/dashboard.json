                    { "formula": "cpu_avg", "alias": "Avg CPU %" },
                    { "formula": "cpu_peak", "alias": "Peak CPU %" }
                  ]
                }
              ],
              "has_search_bar": "auto"
            }
          },
          {
            "definition": {
              "title": "CPU Usage Heatmap",
              "type": "heatmap",
              "requests": [
                { "q": "avg:daytona.sandbox.cpu.utilization{$service} by {service}", "style": { "palette": "dog_classic" } }
              ],
              "yaxis": { "min": "0", "max": "100" }
            }
          }
        ]
      }
    },
