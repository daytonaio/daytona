          },
          {
            "definition": {
              "title": "CPU Limit / Avg / Peak by Service",
              "type": "query_table",
              "requests": [
                {
                  "queries": [
                    {
                      "data_source": "metrics",
                      "name": "cpu_limit",
                      "query": "avg:daytona.sandbox.cpu.limit{$service} by {service}",
