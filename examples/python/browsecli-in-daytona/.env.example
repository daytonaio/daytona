# Browserbase — the Verified browser the in-sandbox `browse` CLI connects to.
# Get these from https://www.browserbase.com/settings
BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxxxxxxx

# Daytona — the sandbox the agent loop runs in.
# Get this from https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=dtn_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the protected page the demo visits (default https://nowsecure.nl)
# TARGET_URL=https://nowsecure.nl
