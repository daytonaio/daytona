# Required by the orchestrator and snapshot builder.
ENVIRONMENT_ID=
ANTHROPIC_ENVIRONMENT_KEY=
DAYTONA_API_KEY=

# Needed for create_agent.py (a one-time setup helper).
# Also what your customer-facing application uses to create sessions
# and stream events.
ANTHROPIC_API_KEY=

# Webhook mode only. Polling mode does not need a webhook secret.
# ANTHROPIC_WEBHOOK_SECRET=

# Optional tuning.
# PORT=5051
# JANITOR_SECONDS=60
# RUNNER_MAX_IDLE_SECONDS=300
# MAX_IDLE_DAYS=30
# RUNNER_LAUNCH_PROBE_SECONDS=3
# RUNNER_REPLACE_GRACE_SECONDS=10
# POLL_BLOCK_MS=999
# POLL_RECLAIM_OLDER_THAN_MS=2000
# WEBHOOK_DRAIN_SECONDS=30
# WEBHOOK_RECLAIM_OLDER_THAN_MS=2000
# LOG_LEVEL=INFO
# ORCHESTRATOR_LOCK_FILE=/tmp/anthropic-selfhosted-orchestrator-{ENVIRONMENT_ID}.lock

# Optional override of the hash-derived default snapshot name.
# DEFAULT_SNAPSHOT_NAME=
