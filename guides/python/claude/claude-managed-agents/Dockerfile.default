FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    CARGO_HOME=/usr/local/cargo \
    RUSTUP_HOME=/usr/local/rustup \
    PATH=/usr/local/go/bin:/usr/local/cargo/bin:/opt/gradle/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin

# Base packages and build deps for everything compiled later (Ruby, Python ext, etc.)
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl wget gnupg lsb-release software-properties-common \
        apt-transport-https \
        build-essential autoconf bison pkg-config \
        libssl-dev libyaml-dev libreadline-dev zlib1g-dev libncurses5-dev \
        libffi-dev libgdbm-dev libdb-dev \
        git unzip zip tar xz-utils \
        sudo locales \
    && locale-gen en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

# Add third-party apt sources: deadsnakes (Python 3.12), Ondrej (PHP 8.3),
# ubuntu-toolchain (GCC 13), Adoptium Temurin (Java 21), NodeSource (Node 20).
RUN add-apt-repository -y ppa:deadsnakes/ppa \
    && add-apt-repository -y ppa:ondrej/php \
    && add-apt-repository -y ppa:ubuntu-toolchain-r/test \
    && wget -qO- https://packages.adoptium.net/artifactory/api/gpg/key/public \
        | gpg --dearmor -o /etc/apt/trusted.gpg.d/adoptium.gpg \
    && echo "deb https://packages.adoptium.net/artifactory/deb $(lsb_release -cs) main" \
        > /etc/apt/sources.list.d/adoptium.list \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash -

# Languages and runtimes from apt.
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-venv python3.12-dev \
        nodejs \
        temurin-21-jdk \
        php8.3 php8.3-cli php8.3-common php8.3-curl php8.3-mbstring \
            php8.3-xml php8.3-zip \
        gcc-13 g++-13 \
        maven \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-13 60 \
    && update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-13 60

RUN curl -fsSL https://bootstrap.pypa.io/get-pip.py | python3.12 \
    && pip install --no-cache-dir uv

RUN npm install -g yarn pnpm

# Go: official tarball.
ARG GO_VERSION=1.22.10
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
        | tar -C /usr/local -xz

# Rust: rustup with stable toolchain.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile minimal \
    && chmod -R a+rwX /usr/local/cargo /usr/local/rustup

# Ruby: ruby-build standalone (compiles from source).
ARG RUBY_VERSION=3.3.6
RUN git clone --depth 1 https://github.com/rbenv/ruby-build.git /tmp/ruby-build \
    && PREFIX=/usr/local /tmp/ruby-build/install.sh \
    && ruby-build "${RUBY_VERSION}" /usr/local \
    && rm -rf /tmp/ruby-build \
    && gem install --no-document bundler

# Composer (PHP).
RUN curl -sS https://getcomposer.org/installer \
        | php -- --install-dir=/usr/local/bin --filename=composer

# Gradle: apt version is too old for Java 21; install 8.x from upstream.
ARG GRADLE_VERSION=8.10.2
RUN curl -fsSL "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip" \
        -o /tmp/gradle.zip \
    && unzip -q /tmp/gradle.zip -d /opt \
    && mv "/opt/gradle-${GRADLE_VERSION}" /opt/gradle \
    && rm /tmp/gradle.zip

# Database clients (servers not started; sqlite is local-use).
RUN apt-get update && apt-get install -y --no-install-recommends \
        sqlite3 postgresql-client redis-tools \
    && rm -rf /var/lib/apt/lists/*

# System utilities. docker.io is installed but dockerd is not autostarted;
# an agent that needs it runs `dockerd &` on first use.
RUN apt-get update && apt-get install -y --no-install-recommends \
        jq vim nano tmux screen htop tree ripgrep \
        openssh-client \
        cmake \
        diffutils patch \
        docker.io \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /mnt/session && chmod 777 /mnt/session

WORKDIR /mnt/session
