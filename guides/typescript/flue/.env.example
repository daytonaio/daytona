# Required: Daytona API key. Provisioned at https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=

# Required: Anthropic API key (used for the default model, claude-sonnet-4-6).
# If you switch MODEL to an OpenAI/OpenRouter model, set the corresponding key instead.
ANTHROPIC_API_KEY=

# Required: GitHub Personal Access Token (classic) with `repo` scope.
# Used by `gh` inside the sandbox to clone, push branches, and open PRs.
# Create one at https://github.com/settings/tokens/new
GITHUB_TOKEN=

# Optional: Override this agent's default model.
# Any `provider/model-id` recognized by @mariozechner/pi-ai works.
# Browse the registry: https://www.npmjs.com/package/@mariozechner/pi-ai
# Examples:
#   anthropic/claude-sonnet-4-6   (this agent's default, used when MODEL is unset)
#   anthropic/claude-opus-4-7
#   openai/gpt-5.5
MODEL=anthropic/claude-sonnet-4-6

# Default demo target. Used if the HTTP payload does not specify { repo, issueNumber }.
# Override per-call by sending a JSON body to the webhook.
#
# Format: <owner>/<repo> slug, NOT a URL.
#   correct:    your-username/your-fork
#   incorrect:  https://github.com/your-username/your-fork
#
# DEMO_REPO is your fork (where branches and the PR will land).
# The agent fetches the issue from the fork's UPSTREAM parent automatically
# (GitHub disables issues on forks by default, so the issue lives on the upstream).
# Set ISSUE_REPO below ONLY if your repo is not a fork or you want to point
# the agent at a different issue source.
DEMO_REPO=your-username/your-fork
DEMO_ISSUE=

# Optional: Override the auto-detected issue source. Same <owner>/<repo> slug format.
# If unset, the agent runs `gh repo view ${DEMO_REPO} --json parent` and uses
# the parent. Set this when:
#   - your DEMO_REPO is not a fork (no parent) and you want to point at a different repo
#   - you have enabled issues on your fork and want to use those instead of upstream's
# ISSUE_REPO=
