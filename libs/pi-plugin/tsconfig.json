{
  // Standalone on purpose (does not extend tsconfig.base.json): this is a jiti-loaded
  // ESM extension using .ts-extension imports + noEmit, which conflicts with the base's
  // commonjs/node-resolution/importHelpers build model.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "../..",
    "paths": {
      "@daytona/sdk": ["libs/sdk-typescript/src/index.ts"]
    }
  },
  "include": ["index.ts", "src/**/*.ts"]
}
