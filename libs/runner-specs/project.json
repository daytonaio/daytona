{
  "name": "runner-specs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/runner-specs",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["generate:specs"],
      "options": {
        "outputPath": "dist/libs/runner-specs",
        "tsConfig": "libs/runner-specs/tsconfig.lib.json",
        "packageJson": "libs/runner-specs/package.json",
        "main": "libs/runner-specs/src/index.ts",
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "generate:specs": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/libs/runner-specs/src/generated",
        "{workspaceRoot}/apps/runner/pkg/runner/v2/specs/gen"
      ],
      "options": {
        "commands": [
          "which protoc-gen-go > /dev/null 2>&1 || go install google.golang.org/protobuf/cmd/protoc-gen-go@latest",
          "which protoc-gen-ts_proto > /dev/null 2>&1 || npm install -g ts-proto",
          "which protoc-go-inject-tag > /dev/null 2>&1 || go install github.com/favadi/protoc-go-inject-tag@latest",
          "npx buf generate --template apps/runner/specs/buf.gen.yaml apps/runner/specs",
          "protoc-go-inject-tag -input=apps/runner/pkg/runner/v2/specs/gen/runner.pb.go -remove_tag_comment",
          "go fmt apps/runner/pkg/runner/v2/specs/gen/runner.pb.go"
        ],
        "parallel": false
      }
    }
  },
  "tags": []
}
