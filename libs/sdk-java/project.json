{
  "name": "sdk-java",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/sdk-java/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["default"],
      "outputs": ["{projectRoot}/build"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "./gradlew build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "commands": [
          "examples/java/gradlew -p examples/java/lifecycle run",
          "examples/java/gradlew -p examples/java/exec-command run",
          "examples/java/gradlew -p examples/java/file-operations run",
          "examples/java/gradlew -p examples/java/git run",
          "examples/java/gradlew -p examples/java/auto-archive run",
          "examples/java/gradlew -p examples/java/auto-delete run",
          "examples/java/gradlew -p examples/java/declarative-image run",
          "examples/java/gradlew -p examples/java/network-settings run",
          "examples/java/gradlew -p examples/java/pagination run",
          "examples/java/gradlew -p examples/java/volumes run",
          "examples/java/gradlew -p examples/java/region run",
          "examples/java/gradlew -p examples/java/pty run"
        ],
        "parallel": false
      },
      "dependsOn": ["build"]
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "./gradlew clean"
      }
    }
  }
}
