{
  "name": "toolbox-api-client-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/toolbox-api-client-go",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["goProduction", "^goProduction"],
      "outputs": [],
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["go mod download", "go build -v ./..."],
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": ["go clean", "rm -rf dist"],
        "parallel": false
      }
    },
    "generate:api-client": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["goApiClient"],
      "outputs": [
        "{projectRoot}/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{projectRoot}/api/openapi.yaml"
      ],
      "options": {
        "commands": [
          "rm -f {projectRoot}/*.go",
          "yarn run openapi-generator-cli generate --git-repo-id=daytona/libs/toolbox-api-client-go --git-user-id=daytonaio -i apps/daemon/pkg/toolbox/docs/swagger.json -g go -t hack/go-client/openapi-templates --additional-properties=packageName=toolbox,moduleVersion=$DEFAULT_PACKAGE_VERSION,generateInterfaces=true,enumClassPrefix=true,structPrefix=true,enumUnknownDefaultCase=true -o libs/toolbox-api-client-go",
          "bash hack/go-client/postprocess.sh libs/toolbox-api-client-go toolbox toolbox-api-client-go"
        ],
        "parallel": false
      },
      "dependsOn": [
        {
          "target": "openapi",
          "projects": "daemon"
        }
      ]
    },
    "check-version-env": {},
    "set-version": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/libs/sdk-go/go.mod",
        { "env": "VERSION" },
        { "dependentTasksOutputFiles": "**/*", "transitive": true }
      ],
      "outputs": ["{workspaceRoot}/libs/sdk-go/go.mod", "{projectRoot}/VERSION"],
      "options": {
        "cwd": "{workspaceRoot}",
        "commands": [
          "cd libs/sdk-go && go mod edit -require=github.com/daytonaio/daytona/libs/toolbox-api-client-go@$VERSION",
          "echo \"$VERSION\" > libs/toolbox-api-client-go/VERSION"
        ],
        "parallel": false
      },
      "dependsOn": ["check-version-env"]
    }
  },
  "tags": []
}
